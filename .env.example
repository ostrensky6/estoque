# Local development defaults. Copy to .env.local only when needed.
# Do not commit real service-role keys, database passwords, or production DB URLs.

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# For Supabase local after `npx supabase start`.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54521
NEXT_PUBLIC_SUPABASE_ANON_KEY=<local-anon-key-from-supabase-start>

# Production public URL, documented for reference only:
# NEXT_PUBLIC_SUPABASE_URL=https://hhxwdcwphitfxywbgtju.supabase.co

# Server/admin credentials belong in Vercel Production or an audited local shell,
# not in this example file.
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_AUTH_ADMIN_KEY=
# DATABASE_URL=
# POSTGRES_URL=
